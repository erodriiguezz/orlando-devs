---
import MainLayout from "../layouts/MainLayout.astro";
import EventsCalendar from "../ReactComponents/EventsCalendar.tsx";
import { fetchLumaEvents } from "../services/lumaService";

// Fetch events data
const events = await fetchLumaEvents();
---

<MainLayout
  title="Orlando Devs - Events"
  description="Discover upcoming events for Orlando Devs, a community of developers in the Greater Orlando area. Join us for meetups, workshops, and more!"
>
  <EventsCalendar client:load initialEvents={events} />
</MainLayout>
