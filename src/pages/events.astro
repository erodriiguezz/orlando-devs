---
import MainLayout from "../layouts/MainLayout.astro";
import EventsHeader from "../components/EventsHeader.astro";
import EventsCalendar from "../ReactComponents/EventsCalendar.tsx";
import EventsFooter from "../components/EventsFooter.astro";
import { getCollection } from "astro:content";

const events = await getCollection("events");
---

<MainLayout title="Events Calendar - Orlando Devs">
  <EventsHeader />

  <EventsCalendar client:load events={events} />

  <EventsFooter />
</MainLayout>
